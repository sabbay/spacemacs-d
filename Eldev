;; -*- mode: emacs-lisp; lexical-binding: t -*-
;;
;; Eldev project file. This repo is a Spacemacs config, not a
;; distributable package — so we don't try to treat it like one
;; (no Package-Requires header, no `melpa-stable' target). We only
;; want batch-mode test running and byte-compile checks for the
;; `claude-collab' subsystem.

(eldev-use-package-archive 'gnu)
(eldev-use-package-archive 'melpa)

;; The package metadata we care about lives in lisp/claude-collab.el,
;; not at the repo root (the repo is a Spacemacs config with many
;; unrelated layer files alongside).
(setf eldev-project-main-file "lisp/claude-collab.el")

;; Treat the lisp/ directory as both source and tests root.
(eldev-add-loading-roots 'main "lisp")
(eldev-add-loading-roots 'test "lisp")

;; What we actually test.
(setf eldev-test-fileset '("./lisp/*-test.el"))

;; Source files that the lint/byte-compile targets care about.
;; Only the claude-collab subsystem — the rest of lisp/ and especially
;; init.el is Spacemacs-internal and doesn't benefit from this rig.
(setf eldev-main-fileset '("./lisp/claude-collab*.el"
                           "!./lisp/claude-collab*-test.el"))
(setf eldev-files-to-package eldev-main-fileset)

;; Runtime deps we expect to be available when tests load
;; claude-collab.el. These are pulled from MELPA into .eldev/ on
;; first run; they're development-time only.
(eldev-add-extra-dependencies 'runtime 'org-remark)
(eldev-add-extra-dependencies 'test 'org-remark)

;; Lint scope. We're not a distributable MELPA package, so skip:
;; - `package' / `package-lint' — would demand a proper Package-Requires
;;   header on a Spacemacs config we never publish
;; - the `indent-character' / `fill-column' / `trailing-whitespace'
;;   sub-checks of `elisp-lint' which fire false positives on
;;   space-indented elisp + multi-paragraph docstrings (Emacs convention,
;;   not the elisp-lint default's expectation).
;; What stays: byte-compile, checkdoc, and the relint regex linter.
(setf eldev-lint-default '(elisp))
(setf eldev-lint-disabled '(package))
(setq elisp-lint-ignored-validators
      '("indent-character" "fill-column" "trailing-whitespace"))

;; Modern Emacs Lisp uses single space after period in docstrings; the
;; default `sentence-end-double-space' is t. Without flipping it,
;; checkdoc fires on every period in every docstring — pure noise.
(setq sentence-end-double-space nil)
